{
  "$id": "urn:edgp:schema:albs-build-diff:v1",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": true,
  "description": "ALBS build comparison report for public build metadata.",
  "properties": {
    "addedArtifacts": {"items": {"type": "object"}, "type": "array"},
    "changedArtifacts": {"items": {"type": "object"}, "type": "array"},
    "ecosystem": {"const": "albs"},
