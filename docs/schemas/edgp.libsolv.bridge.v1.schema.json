{
  "$id": "urn:edgp:schema:libsolv-bridge:v1",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": true,
  "description": "libsolv command availability, normalized transaction, and optional graph match report.",
  "properties": {
    "commands": {
      "items": {
        "additionalProperties": true,
        "properties": {
          "available": {"type": "boolean"},
          "command": {"type": "string"},
          "path": {"type": "string"}
        },
        "required": ["command", "available", "path"],
        "type": "object"
      },
      "type": "array"
    },
    "ecosystem": {"const": "rpm"},
    "graphContext": {
      "additionalProperties": true,
      "properties": {
        "ecosystem": {"type": "string"},
        "edges": {"type": "integer"},
        "nodes": {"type": "integer"},
        "root": {"type": "string"},
        "schema": {"type": "string"},
        "source": {"type": "string"}
      },
      "required": ["source", "schema", "ecosystem", "root", "nodes", "edges"],
      "type": "object"
    },
    "integration": {"items": {"type": "string"}, "type": "array"},
    "schema": {"const": "edgp.libsolv.bridge.v1"},
    "summary": {
      "additionalProperties": true,
      "properties": {
        "architectures": {
          "items": {
            "additionalProperties": true,
            "properties": {
              "actions": {"type": "integer"},
              "arch": {"type": "string"}
            },
            "required": ["arch", "actions"],
            "type": "object"
          },
          "type": "array"
        },
        "commandsAvailable": {"type": "integer"},
        "erases": {"type": "integer"},
        "graphAffectedDependents": {"type": "integer"},
        "graphCandidateActions": {"type": "integer"},
        "graphCandidatePackageMatches": {"type": "integer"},
        "graphExactActions": {"type": "integer"},
        "graphExactPackageMatches": {"type": "integer"},
        "graphImpactedActions": {"type": "integer"},
        "graphMatchedActions": {"type": "integer"},
        "graphUnmatchedActions": {"type": "integer"},
        "installs": {"type": "integer"},
        "maxGraphAffectedDependents": {"type": "integer"},
        "parsedPackages": {"type": "integer"},
        "transactionActions": {"type": "integer"},
        "upgrades": {"type": "integer"}
      },
      "required": [
        "commandsAvailable",
        "transactionActions",
        "parsedPackages",
        "installs",
        "erases",
        "upgrades",
        "architectures"
      ],
      "type": "object"
    },
    "transactionActions": {
      "items": {
        "additionalProperties": true,
        "properties": {
          "action": {"type": "string"},
          "graphAffectedDependents": {"type": "integer"},
          "graphMatchedNodeIds": {"items": {"type": "string"}, "type": "array"},
          "graphMatches": {
            "items": {"$ref": "#/$defs/graphMatch"},
            "type": "array"
          },
          "graphMatchStatus": {"type": "string"},
          "newNodeId": {"type": "string"},
          "newPackage": {"type": "string"},
          "newPackageMetadata": {"$ref": "#/$defs/packageMetadata"},
          "nodeId": {"type": "string"},
          "oldNodeId": {"type": "string"},
          "oldPackage": {"type": "string"},
          "oldPackageMetadata": {"$ref": "#/$defs/packageMetadata"},
          "package": {"type": "string"},
          "packageArch": {"type": "string"},
          "packageMetadata": {"$ref": "#/$defs/packageMetadata"},
          "packageName": {"type": "string"},
          "packageRelease": {"type": "string"},
          "packageVersion": {"type": "string"},
          "purl": {"type": "string"}
        },
        "required": ["action", "package", "oldPackage", "newPackage"],
        "type": "object"
      },
      "type": "array"
    },
    "transactionImpact": {
      "items": {"$ref": "#/$defs/transactionImpact"},
      "type": "array"
    }
  },
  "$defs": {
    "packageMetadata": {
      "additionalProperties": true,
      "properties": {
        "arch": {"type": "string"},
        "epoch": {"type": "string"},
        "evr": {"type": "string"},
        "name": {"type": "string"},
        "nodeId": {"type": "string"},
        "purl": {"type": "string"},
        "raw": {"type": "string"},
        "release": {"type": "string"},
        "version": {"type": "string"}
      },
      "required": [
        "raw",
        "name",
        "epoch",
        "version",
        "release",
        "evr",
        "arch",
        "nodeId",
        "purl"
      ],
      "type": "object"
    },
    "transactionImpact": {
      "additionalProperties": true,
      "properties": {
        "action": {"type": "string"},
        "actionIndex": {"type": "integer"},
        "affectedDependents": {"type": "integer"},
        "directDependents": {"type": "integer"},
        "matchedNodeIds": {"items": {"type": "string"}, "type": "array"},
        "matchedRoles": {"items": {"type": "string"}, "type": "array"},
        "matchStatus": {"type": "string"},
        "packageArch": {"type": "string"},
        "packageName": {"type": "string"},
        "purl": {"type": "string"}
      },
      "required": [
        "actionIndex",
        "action",
        "packageName",
        "packageArch",
        "matchStatus",
        "matchedRoles",
        "matchedNodeIds",
        "directDependents",
        "affectedDependents",
        "purl"
      ],
      "type": "object"
    },
    "graphMatch": {
      "additionalProperties": true,
      "properties": {
        "affectedDependents": {"type": "integer"},
        "candidateNodeIds": {"items": {"type": "string"}, "type": "array"},
        "directDependencies": {"type": "integer"},
        "directDependents": {"type": "integer"},
        "matched": {"type": "boolean"},
        "matchType": {"type": "string"},
        "nodeId": {"type": "string"},
        "packageArch": {"type": "string"},
        "packageName": {"type": "string"},
        "requestedNodeId": {"type": "string"},
        "role": {"type": "string"}
      },
      "required": [
        "role",
        "matched",
        "matchType",
        "requestedNodeId",
        "packageName",
        "packageArch",
        "nodeId",
        "candidateNodeIds",
        "directDependencies",
        "directDependents",
        "affectedDependents"
      ],
      "type": "object"
    }
  },
  "required": [
    "schema",
    "ecosystem",
    "summary",
    "commands",
    "transactionActions",
    "integration"
  ],
  "title": "EDGP libsolv Bridge v1",
  "type": "object"
}
