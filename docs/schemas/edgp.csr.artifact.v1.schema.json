{
  "$id": "urn:edgp:schema:csr-artifact:v1",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Memory-mappable frozen CSR graph artifact manifest with array digests.",
  "properties": {
    "arrays": {
      "additionalProperties": {
        "additionalProperties": false,
        "properties": {
          "dtype": {"const": "int32"},
          "path": {"type": "string"},
          "sha256": {"pattern": "^[0-9a-f]{64}$", "type": "string"},
          "shape": {"items": {"type": "integer"}, "type": "array"}
        },
        "required": ["path", "dtype", "shape", "sha256"],
        "type": "object"
      },
      "type": "object"
    },
    "dtype": {"const": "int32"},
    "edges": {"minimum": 0, "type": "integer"},
    "layout": {"const": "frozen_csr_numpy_npy_directory"},
    "layoutVersion": {"const": 1},
    "matrixViews": {
      "additionalProperties": false,
      "properties": {
        "csc": {
          "additionalProperties": false,
          "properties": {
            "direction": {"const": "incoming_dependents"},
            "format": {"const": "csc"},
            "indices": {"const": "reverse_column_indices"},
            "indptr": {"const": "reverse_row_pointers"},
            "materialization": {"const": "reverse_csr_transpose"},
            "values": {"const": "reverse_values"}
          },
          "required": [
            "format",
            "direction",
            "values",
            "indices",
            "indptr",
            "materialization"
          ],
          "type": "object"
        },
        "csr": {
          "additionalProperties": false,
          "properties": {
            "direction": {"const": "outgoing_dependencies"},
            "format": {"const": "csr"},
            "indices": {"const": "column_indices"},
            "indptr": {"const": "row_pointers"},
            "values": {"const": "values"}
          },
          "required": ["format", "direction", "values", "indices", "indptr"],
          "type": "object"
        }
      },
      "required": ["csr", "csc"],
      "type": "object"
    },
    "nodes": {"minimum": 0, "type": "integer"},
    "packageIds": {"items": {"type": "string"}, "type": "array"},
    "schema": {"const": "edgp.csr.artifact.v1"},
    "storageProfile": {
      "additionalProperties": false,
      "properties": {
        "arrayCount": {"const": 6},
        "cContiguous": {"const": true},
        "columnIndicesBytes": {"minimum": 0, "type": "integer"},
        "digestAlgorithm": {"const": "sha256"},
        "digestCoverage": {
          "items": {
            "enum": [
              "values",
              "column_indices",
              "row_pointers",
              "reverse_values",
              "reverse_column_indices",
              "reverse_row_pointers"
            ],
            "type": "string"
          },
          "maxItems": 6,
          "minItems": 6,
          "uniqueItems": true,
          "type": "array"
        },
        "dtype": {"const": "int32"},
        "forwardBytes": {"minimum": 0, "type": "integer"},
        "layout": {"const": "numpy.int32.c_contiguous"},
        "memoryMappable": {"const": true},
        "mmapMode": {"const": "r"},
        "readOnly": {"const": true},
        "reverseBytes": {"minimum": 0, "type": "integer"},
        "reverseColumnIndicesBytes": {"minimum": 0, "type": "integer"},
        "reverseRowPointersBytes": {"minimum": 0, "type": "integer"},
        "reverseValuesBytes": {"minimum": 0, "type": "integer"},
        "rowPointersBytes": {"minimum": 0, "type": "integer"},
        "runtime": {"const": "frozen"},
        "totalBytes": {"minimum": 0, "type": "integer"},
        "valuesBytes": {"minimum": 0, "type": "integer"}
      },
      "required": [
        "layout",
        "dtype",
        "valuesBytes",
        "columnIndicesBytes",
        "rowPointersBytes",
        "reverseValuesBytes",
        "reverseColumnIndicesBytes",
        "reverseRowPointersBytes",
        "totalBytes",
        "cContiguous",
        "runtime",
        "readOnly",
        "arrayCount",
        "digestAlgorithm",
        "digestCoverage",
        "forwardBytes",
        "memoryMappable",
        "mmapMode",
        "reverseBytes"
      ],
      "type": "object"
    },
    "vertexMetadata": {
      "additionalProperties": {
        "additionalProperties": {"type": "string"},
        "type": "object"
      },
      "type": "object"
    }
  },
  "required": [
    "schema",
    "layout",
    "layoutVersion",
    "dtype",
    "nodes",
    "edges",
    "arrays",
    "matrixViews",
    "storageProfile",
    "packageIds",
    "vertexMetadata"
  ],
  "title": "EDGP CSR Artifact Manifest v1",
  "type": "object"
}
