{
  "$id": "urn:edgp:schema:graph-diff-tree:v1",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Focused dependency or dependent cone diff around one selected node in two EDGP graph snapshots.",
  "properties": {
    "classifications": {"items": {"$ref": "#/$defs/classification"}, "type": "array"},
    "depth": {"minimum": 0, "type": "integer"},
    "direction": {"enum": ["dependencies", "dependents"]},
    "edges": {
      "additionalProperties": false,
      "properties": {
        "added": {"items": {"$ref": "#/$defs/edge"}, "type": "array"},
        "removed": {"items": {"$ref": "#/$defs/edge"}, "type": "array"},
        "unchanged": {"items": {"$ref": "#/$defs/edge"}, "type": "array"}
      },
      "required": ["added", "removed", "unchanged"],
      "type": "object"
    },
    "leftNode": {"type": ["string", "null"]},
    "leftRoot": {"type": ["string", "null"]},
    "leftSelector": {"minLength": 1, "type": "string"},
    "neighborhoods": {
      "additionalProperties": false,
      "properties": {
        "left": {"$ref": "#/$defs/neighborhood"},
        "right": {"$ref": "#/$defs/neighborhood"}
      },
      "required": ["left", "right"],
      "type": "object"
    },
    "nodes": {
      "additionalProperties": false,
      "properties": {
        "added": {"items": {"$ref": "#/$defs/node"}, "type": "array"},
        "metadataChanged": {
          "items": {"$ref": "#/$defs/metadataChange"},
          "type": "array"
        },
        "removed": {"items": {"$ref": "#/$defs/node"}, "type": "array"},
        "unchanged": {"items": {"type": "string"}, "type": "array"}
      },
      "required": ["added", "removed", "metadataChanged", "unchanged"],
      "type": "object"
    },
    "policy": {"$ref": "#/$defs/policy"},
    "rightNode": {"type": ["string", "null"]},
    "rightRoot": {"type": ["string", "null"]},
    "rightSelector": {"minLength": 1, "type": "string"},
    "schema": {"const": "edgp.graph.diff_tree.v1"},
    "selector": {"minLength": 1, "type": "string"},
    "summary": {
      "additionalProperties": false,
      "properties": {
        "addedEdges": {"minimum": 0, "type": "integer"},
        "addedNodes": {"minimum": 0, "type": "integer"},
        "addedOnlyChanges": {"minimum": 0, "type": "integer"},
        "classifiedChanges": {"minimum": 0, "type": "integer"},
        "downgradeChanges": {"minimum": 0, "type": "integer"},
        "edgeChurn": {"minimum": 0, "type": "integer"},
        "edgeDelta": {"type": "integer"},
        "leftNodes": {"minimum": 0, "type": "integer"},
        "leftEdges": {"minimum": 0, "type": "integer"},
        "metadataChangedNodes": {"minimum": 0, "type": "integer"},
        "metadataOnlyChanges": {"minimum": 0, "type": "integer"},
        "nodeChurn": {"minimum": 0, "type": "integer"},
        "nodeDelta": {"type": "integer"},
        "removedEdges": {"minimum": 0, "type": "integer"},
        "removedNodes": {"minimum": 0, "type": "integer"},
        "removedOnlyChanges": {"minimum": 0, "type": "integer"},
        "replacementChanges": {"minimum": 0, "type": "integer"},
        "rightEdges": {"minimum": 0, "type": "integer"},
        "rightNodes": {"minimum": 0, "type": "integer"},
        "unchangedEdges": {"minimum": 0, "type": "integer"},
        "unchangedNodes": {"minimum": 0, "type": "integer"},
        "upgradeChanges": {"minimum": 0, "type": "integer"}
      },
      "required": [
        "leftNodes",
        "rightNodes",
        "nodeDelta",
        "addedNodes",
        "removedNodes",
        "metadataChangedNodes",
        "nodeChurn",
        "unchangedNodes",
        "leftEdges",
        "rightEdges",
        "edgeDelta",
        "addedEdges",
        "removedEdges",
        "edgeChurn",
        "unchangedEdges",
        "classifiedChanges",
        "upgradeChanges",
        "downgradeChanges",
        "replacementChanges",
        "addedOnlyChanges",
        "removedOnlyChanges",
        "metadataOnlyChanges"
      ],
      "type": "object"
    },
    "topFindings": {
      "additionalProperties": false,
      "description": "Bounded high-signal findings for CI, workbench, and RAG consumers that need a compact focused snapshot-diff summary.",
      "properties": {
        "packageChanges": {
          "items": {"$ref": "#/$defs/classification"},
          "type": "array"
        }
      },
      "required": ["packageChanges"],
      "type": "object"
    }
  },
  "required": [
    "schema",
    "selector",
    "direction",
    "depth",
    "leftSelector",
    "rightSelector",
    "leftRoot",
    "rightRoot",
    "leftNode",
    "rightNode",
    "summary",
    "nodes",
    "classifications",
    "edges",
    "neighborhoods"
  ],
  "title": "EDGP Graph Diff Tree v1",
  "type": "object",
  "$defs": {
    "classification": {
      "additionalProperties": false,
      "properties": {
        "changedKeys": {"items": {"type": "string"}, "type": "array"},
        "kind": {
          "enum": [
            "added",
            "downgrade",
            "metadataChange",
            "removed",
            "replacement",
            "upgrade"
          ]
        },
        "leftDistance": {"minimum": 0, "type": "integer"},
        "leftNode": {"type": "string"},
        "leftPath": {"items": {"type": "string"}, "type": "array"},
        "leftVersion": {"type": "string"},
        "name": {"type": "string"},
        "node": {"type": "string"},
        "pairIndex": {"minimum": 0, "type": "integer"},
        "rightDistance": {"minimum": 0, "type": "integer"},
        "rightNode": {"type": "string"},
        "rightPath": {"items": {"type": "string"}, "type": "array"},
        "rightVersion": {"type": "string"}
      },
      "required": ["kind", "name"],
      "type": "object"
    },
    "edge": {
      "additionalProperties": false,
      "properties": {
        "relationshipType": {"minimum": 1, "type": "integer"},
        "source": {"minLength": 1, "type": "string"},
        "target": {"minLength": 1, "type": "string"}
      },
      "required": ["source", "target", "relationshipType"],
      "type": "object"
    },
    "metadataChange": {
      "additionalProperties": false,
      "properties": {
        "changedKeys": {"items": {"type": "string"}, "type": "array"},
        "id": {"minLength": 1, "type": "string"},
        "leftDistance": {"minimum": 0, "type": "integer"},
        "leftMetadata": {"type": "object"},
        "leftPath": {"items": {"type": "string"}, "type": "array"},
        "rightDistance": {"minimum": 0, "type": "integer"},
        "rightMetadata": {"type": "object"},
        "rightPath": {"items": {"type": "string"}, "type": "array"}
      },
      "required": ["id", "changedKeys", "leftMetadata", "rightMetadata"],
      "type": "object"
    },
    "neighborhood": {
      "additionalProperties": false,
      "properties": {
        "edges": {"items": {"$ref": "#/$defs/edge"}, "type": "array"},
        "nodes": {"items": {"type": "string"}, "type": "array"}
      },
      "required": ["nodes", "edges"],
      "type": "object"
    },
    "node": {
      "additionalProperties": false,
      "properties": {
        "distance": {"minimum": 0, "type": "integer"},
        "id": {"minLength": 1, "type": "string"},
        "metadata": {"type": "object"},
        "name": {"minLength": 1, "type": "string"},
        "path": {"items": {"type": "string"}, "type": "array"},
        "version": {"type": "string"}
      },
      "required": ["id", "name", "version", "metadata"],
      "type": "object"
    },
    "policy": {
      "additionalProperties": false,
      "properties": {
        "exitCode": {"enum": [0, 2]},
        "failOnKind": {
          "items": {
            "enum": [
              "added",
              "downgrade",
              "metadataChange",
              "removed",
              "replacement",
              "upgrade"
            ]
          },
          "type": "array",
          "uniqueItems": true
        },
        "matchedKinds": {
          "items": {
            "enum": [
              "added",
              "downgrade",
              "metadataChange",
              "removed",
              "replacement",
              "upgrade"
            ]
          },
          "type": "array",
          "uniqueItems": true
        },
        "status": {"enum": ["fail", "pass"]}
      },
      "required": ["failOnKind", "matchedKinds", "status", "exitCode"],
      "type": "object"
    }
  }
}
