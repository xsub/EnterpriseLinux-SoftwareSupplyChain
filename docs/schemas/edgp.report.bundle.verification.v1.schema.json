{
  "$id": "urn:edgp:schema:report-bundle-verification:v1",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Verification report emitted by edgp verify-bundle for EDGP static report bundles.",
  "properties": {
    "bundleDir": {
      "description": "Resolved bundle directory that was verified.",
      "minLength": 1,
      "type": "string"
    },
    "bundleSha256": {
      "description": "Manifest bundle fingerprint when available, or null when the manifest could not provide one.",
      "oneOf": [
        {
          "pattern": "^[0-9a-f]{64}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "failures": {
      "description": "Ordered verification failures found while checking manifest shape, bundle fingerprint, and member file digests.",
      "items": {
        "additionalProperties": false,
        "properties": {
          "code": {
            "description": "Stable machine-readable failure category.",
            "minLength": 1,
            "pattern": "^[A-Za-z][A-Za-z0-9]*$",
            "type": "string"
          },
          "message": {
            "description": "Human-readable failure detail.",
            "minLength": 1,
            "type": "string"
          },
          "path": {
            "description": "Manifest, index, source, or rendered HTML path related to this failure.",
            "minLength": 1,
            "type": "string"
          }
        },
        "required": [
          "code",
          "message",
          "path"
        ],
        "type": "object"
      },
      "type": "array"
    },
    "manifest": {
      "description": "Manifest filename that was read from the bundle directory.",
      "minLength": 1,
      "type": "string"
    },
    "ok": {
      "description": "True when no verification failures were found.",
      "type": "boolean"
    },
    "schema": {
      "const": "edgp.report.bundle.verification.v1",
      "description": "Verification report schema identifier."
    },
    "summary": {
      "additionalProperties": false,
      "description": "Compact verification counters.",
      "properties": {
        "failures": {
          "description": "Number of verification failures.",
          "minimum": 0,
          "type": "integer"
        },
        "reports": {
          "description": "Number of manifest report entries seen by the verifier.",
          "minimum": 0,
          "type": "integer"
        }
      },
      "required": [
        "reports",
        "failures"
      ],
      "type": "object"
    }
  },
  "required": [
    "schema",
    "bundleDir",
    "manifest",
    "ok",
    "bundleSha256",
    "summary",
    "failures"
  ],
  "title": "EDGP Report Bundle Verification v1",
  "type": "object"
}
