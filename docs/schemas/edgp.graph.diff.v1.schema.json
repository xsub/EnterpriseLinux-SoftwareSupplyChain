{
  "$id": "urn:edgp:schema:graph-diff:v1",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": true,
  "description": "Graph snapshot diff report for two EDGP graph snapshot JSON documents.",
  "properties": {
    "classifications": {
      "items": {"$ref": "#/$defs/classification"},
      "type": "array"
    },
    "edges": {
      "additionalProperties": false,
      "properties": {
        "added": {"items": {"type": "object"}, "type": "array"},
        "removed": {"items": {"type": "object"}, "type": "array"}
      },
      "required": ["added", "removed"],
      "type": "object"
    },
    "leftRoot": {"type": ["string", "null"]},
    "nodes": {
      "additionalProperties": false,
      "properties": {
        "added": {"items": {"type": "string"}, "type": "array"},
        "metadataChanged": {"items": {"type": "string"}, "type": "array"},
        "removed": {"items": {"type": "string"}, "type": "array"}
      },
      "required": ["added", "removed", "metadataChanged"],
      "type": "object"
    },
    "policy": {"$ref": "#/$defs/policy"},
    "rightRoot": {"type": ["string", "null"]},
    "schema": {"const": "edgp.graph.diff.v1"},
    "summary": {
      "additionalProperties": false,
      "properties": {
        "addedEdges": {"minimum": 0, "type": "integer"},
        "addedOnlyChanges": {"minimum": 0, "type": "integer"},
        "addedNodes": {"minimum": 0, "type": "integer"},
        "classifiedChanges": {"minimum": 0, "type": "integer"},
        "downgradeChanges": {"minimum": 0, "type": "integer"},
        "metadataChangedNodes": {"minimum": 0, "type": "integer"},
        "metadataOnlyChanges": {"minimum": 0, "type": "integer"},
        "removedEdges": {"minimum": 0, "type": "integer"},
        "removedNodes": {"minimum": 0, "type": "integer"},
        "removedOnlyChanges": {"minimum": 0, "type": "integer"},
        "replacementChanges": {"minimum": 0, "type": "integer"},
        "upgradeChanges": {"minimum": 0, "type": "integer"}
      },
      "required": [
        "addedNodes",
        "removedNodes",
        "addedEdges",
        "removedEdges",
        "metadataChangedNodes"
      ],
      "type": "object"
    },
    "topFindings": {
      "additionalProperties": false,
      "description": "Bounded high-signal package-change findings for CI, workbench, and RAG consumers that need a compact graph snapshot diff summary.",
      "properties": {
        "packageChanges": {
          "items": {"$ref": "#/$defs/classification"},
          "type": "array"
        }
      },
      "required": ["packageChanges"],
      "type": "object"
    }
  },
  "required": ["schema", "leftRoot", "rightRoot", "summary", "nodes", "edges"],
  "title": "EDGP Graph Diff v1",
  "type": "object",
  "$defs": {
    "classification": {
      "additionalProperties": false,
      "properties": {
        "changedKeys": {"items": {"type": "string"}, "type": "array"},
        "kind": {
          "enum": [
            "added",
            "downgrade",
            "metadataChange",
            "removed",
            "replacement",
            "upgrade"
          ]
        },
        "leftDistance": {"minimum": 0, "type": "integer"},
        "leftNode": {"type": "string"},
        "leftPath": {"items": {"type": "string"}, "type": "array"},
        "leftVersion": {"type": "string"},
        "name": {"type": "string"},
        "node": {"type": "string"},
        "pairIndex": {"minimum": 0, "type": "integer"},
        "rightDistance": {"minimum": 0, "type": "integer"},
        "rightNode": {"type": "string"},
        "rightPath": {"items": {"type": "string"}, "type": "array"},
        "rightVersion": {"type": "string"}
      },
      "required": ["kind", "name"],
      "type": "object"
    },
    "policy": {
      "additionalProperties": false,
      "properties": {
        "exitCode": {"enum": [0, 2], "type": "integer"},
        "failOnChange": {
          "items": {
            "enum": [
              "added-node",
              "removed-node",
              "added-edge",
              "removed-edge",
              "metadata-change"
            ],
            "type": "string"
          },
          "type": "array"
        },
        "failOnKind": {
          "items": {
            "enum": [
              "added",
              "downgrade",
              "metadataChange",
              "removed",
              "replacement",
              "upgrade"
            ],
            "type": "string"
          },
          "type": "array"
        },
        "matchedChanges": {
          "items": {
            "enum": [
              "added-node",
              "removed-node",
              "added-edge",
              "removed-edge",
              "metadata-change"
            ],
            "type": "string"
          },
          "type": "array"
        },
        "matchedKinds": {
          "items": {
            "enum": [
              "added",
              "downgrade",
              "metadataChange",
              "removed",
              "replacement",
              "upgrade"
            ],
            "type": "string"
          },
          "type": "array"
        },
        "status": {"enum": ["pass", "fail"], "type": "string"}
      },
      "required": ["status", "exitCode"],
      "type": "object"
    }
  }
}
